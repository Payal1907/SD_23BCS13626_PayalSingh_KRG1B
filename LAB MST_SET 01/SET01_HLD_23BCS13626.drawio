        <mxCell id="2yODr40lukb6uPuiGOtb-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="1. User Login Service&lt;div&gt;2. Subscriber Service&lt;/div&gt;&lt;div&gt;3. Search Service&lt;/div&gt;&lt;div&gt;4. Play Service&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Use CDC Pipeline, Proxy Design Pattern, HLS/DASH&lt;br&gt;&lt;div&gt;&amp;nbsp;&lt;/div&gt;&lt;/div&gt;" vertex="1">
